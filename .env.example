APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
API_VERSION=v1
SCRAMBLE_API_PATH=api/v1
SCRAMBLE_API_DOMAIN=api.majlisilmu.test
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FILAMENT_ADMIN_DOMAIN=
FILAMENT_AHLI_DOMAIN=
PRODUCT_SIGNALS_PUBLIC_ENABLED=true
PRODUCT_SIGNALS_PUBLIC_PROPERTY_SLUG=
PRODUCT_SIGNALS_ADMIN_ENABLED=true
PRODUCT_SIGNALS_ADMIN_PROPERTY_SLUG=
PRODUCT_SIGNALS_AHLI_ENABLED=true
PRODUCT_SIGNALS_AHLI_PROPERTY_SLUG=
PRODUCT_SIGNALS_ANONYMOUS_COOKIE=mi_signals_anonymous_id
PRODUCT_SIGNALS_SESSION_COOKIE=mi_signals_session_id

APP_LOCALE=ms
APP_FALLBACK_LOCALE=ms
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=majlisilmu
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MEDIA_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=360
MEDIA_QUEUE=media
HORIZON_PATH=horizon

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_ENABLED=false
GOOGLE_PLACES_SERVER_API_KEY=
GOOGLE_PLACE_LINK_RESOLUTION_ENABLED=false

VITE_APP_NAME="${APP_NAME}"

# OCTANE_SERVER=roadrunner
# PERMISSION_OCTANE_RESET_LISTENER=true

# Laravel Scout / Typesense
SCOUT_DRIVER=typesense
SCOUT_QUEUE=true
TYPESENSE_API_KEY=xyz
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http

# AI SDK
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_EVENT_MEDIA_EXTRACTION_PROVIDER=openai
AI_EVENT_MEDIA_EXTRACTION_MODEL=
AI_EVENT_MEDIA_EXTRACTION_MAX_FILE_SIZE_KB=10240
AI_USAGE_TRACKING_ENABLED=true
AI_USAGE_TRACKING_CURRENCY=USD

# Livewire Blaze
BLAZE_ENABLED=true
BLAZE_DEBUG=false
