{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "aiarmada/affiliates": "dev-main",
        "aiarmada/commerce-support": "dev-main",
        "aiarmada/filament-signals": "dev-main",
        "aiarmada/signals": "dev-main",
        "aiarmada/filament-authz": "dev-main",
        "bezhansalleh/filament-language-switch": "dev-main",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-media-library-plugin": "^5.0",
        "filament/spatie-laravel-settings-plugin": "^5.0",
        "filament/spatie-laravel-tags-plugin": "^5.0",
        "http-interop/http-factory-guzzle": "^1.2",
        "itsgoingd/clockwork": "^5.3",
        "laravel/ai": "^0.3.2",
        "laravel/fortify": "^1.33",
        "laravel/framework": "^13.0",
        "laravel/octane": "^2.13",
        "laravel/sanctum": "^4.0",
        "laravel/scout": "^10.23",
        "laravel/socialite": "^5.24",
        "laravel/tinker": "^3.0",
        "livewire/blaze": "^1.0",
        "livewire/flux": "^2.10",
        "lorisleiva/laravel-actions": "^2.9",
        "nnjeim/world": "^1.1",
        "nunomaduro/essentials": "^1.0",
        "owen-it/laravel-auditing": "^14.0",
        "spatie/eloquent-sortable": "^5.0",
        "spatie/laravel-activitylog": "^4.10",
        "spatie/laravel-data": "^4.19",
        "spatie/laravel-deleted-models": "^1.1",
        "spatie/laravel-model-states": "^2.13",
        "spatie/laravel-query-builder": "^6.4",
        "spatie/laravel-sluggable": "^3.7",
        "typesense/typesense-php": "^5.2",
        "ysfkaya/filament-phone-input": "^4.1"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.1",
        "fakerphp/faker": "^1.23",
        "filament/blueprint": "^2.0",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^2.0",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.3",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "name": "aiarmada-affiliates",
            "type": "path",
            "url": "../commerce/packages/affiliates",
            "options": {
                "symlink": true,
                "versions": {
                    "aiarmada/affiliates": "dev-main"
                }
            }
        },
        {
            "name": "aiarmada-signals",
            "type": "path",
            "url": "../commerce/packages/signals",
            "options": {
                "symlink": true,
                "versions": {
                    "aiarmada/signals": "dev-main"
                }
            }
        },
        {
            "name": "aiarmada-filament-signals",
            "type": "path",
            "url": "../commerce/packages/filament-signals",
            "options": {
                "symlink": true,
                "versions": {
                    "aiarmada/filament-signals": "dev-main"
                }
            }
        },
        {
            "name": "aiarmada-filament-authz",
            "type": "path",
            "url": "../commerce/packages/filament-authz",
            "options": {
                "symlink": true,
                "versions": {
                    "aiarmada/filament-authz": "dev-main"
                }
            }
        },
        {
            "name": "aiarmada-commerce-support",
            "type": "path",
            "url": "../commerce/packages/commerce-support",
            "options": {
                "symlink": true,
                "versions": {
                    "aiarmada/commerce-support": "dev-main"
                }
            }
        },
        {
            "type": "package",
            "package": {
                "name": "akaunting/laravel-money",
                "version": "6.0.2",
                "dist": {
                    "url": "https://api.github.com/repos/akaunting/laravel-money/zipball/5dca81f4297b99f8dbf0f4a6bb4d45c56acbd76a",
                    "type": "zip",
                    "reference": "5dca81f4297b99f8dbf0f4a6bb4d45c56acbd76a"
                },
                "source": {
                    "url": "https://github.com/akaunting/laravel-money.git",
                    "type": "git",
                    "reference": "5dca81f4297b99f8dbf0f4a6bb4d45c56acbd76a"
                },
                "require": {
                    "php": "^8.2",
                    "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
                    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
                    "illuminate/validation": "^10.0|^11.0|^12.0|^13.0",
                    "illuminate/view": "^10.0|^11.0|^12.0|^13.0",
                    "vlucas/phpdotenv": "^5.4.1"
                },
                "autoload": {
                    "psr-4": {
                        "Akaunting\\Money\\": "src"
                    },
                    "files": [
                        "src/helpers.php"
                    ]
                },
                "extra": {
                    "laravel": {
                        "providers": [
                            "Akaunting\\Money\\Provider"
                        ]
                    }
                }
            }
        },
        {
            "type": "package",
            "package": {
                "name": "bezhansalleh/filament-language-switch",
                "version": "dev-main",
                "dist": {
                    "url": "https://api.github.com/repos/sairiz/filament-language-switch/zipball/de0483caeba62bf33876f32c3bd4fab1bf06cd45",
                    "type": "zip",
                    "reference": "de0483caeba62bf33876f32c3bd4fab1bf06cd45"
                },
                "source": {
                    "url": "https://github.com/sairiz/filament-language-switch.git",
                    "type": "git",
                    "reference": "de0483caeba62bf33876f32c3bd4fab1bf06cd45"
                },
                "require": {
                    "php": "^8.2",
                    "filament/filament": "^4.0|^5.0",
                    "illuminate/support": "^11.28|^12.0|^13.0",
                    "spatie/laravel-package-tools": "^1.9"
                },
                "autoload": {
                    "psr-4": {
                        "BezhanSalleh\\LanguageSwitch\\": "src"
                    }
                },
                "extra": {
                    "laravel": {
                        "providers": [
                            "BezhanSalleh\\LanguageSwitch\\LanguageSwitchServiceProvider"
                        ]
                    }
                }
            }
        },
        {
            "type": "vcs",
            "url": "https://github.com/sairiz/filament-language-switch"
        },
        {
            "name": "filament",
            "type": "composer",
            "url": "https://packages.filamentphp.com/composer"
        }
    ]
}
