{
  "schema_version": "2.6.0",
  "verified_at": "2026-05-03",
  "title": "API / MCP / Filament Capability Matrix",
  "markdown_companion": "docs/MAJLISILMU_API_MCP_FILAMENT_CRUD_COMPARISON.md",
  "purpose": "Canonical parity map for public workflow API, generic admin HTTP API, admin/member MCP, and the Filament admin/Ahli panels.",
  "source_of_truth_rules": [
    "Runtime panel registration defines the admin and Ahli resource inventories.",
    "Structural support and actor permission are different things: page keys and generic write support show route or tool presence, while middleware and policies decide whether the current actor may use them.",
    "Public and authenticated API routes are workflow-oriented contracts, not a generic mirror of the Filament resource registry.",
    "Admin HTTP API and Admin MCP share the same mutation whitelist through AdminResourceMutationService.",
    "Member MCP is Ahli-scoped: generic CRUD remains update-only and intentionally narrower than the admin generic write contract, while workflow tools extend contribution and membership-claim parity.",
    "Delete, restore, replicate, and reorder remain panel-led concerns."
  ],
  "authoritative_files": {
    "runtime_inventory": [
      "app/Support/Api/Admin/AdminResourceRegistry.php",
      "app/Support/Api/Member/MemberResourceRegistry.php",
      "app/Providers/Filament/AdminPanelProvider.php",
      "app/Providers/Filament/AhliPanelProvider.php",
      "app/Filament/Resources/**/*Resource.php",
      "app/Filament/Ahli/Resources/**/*Resource.php"
    ],
    "generic_admin_writes": [
      "routes/api.php",
      "app/Support/Api/Admin/AdminResourceService.php",
      "app/Support/Api/Admin/AdminResourceMutationService.php",
      "app/Http/Controllers/Api/Admin/ResourceController.php"
    ],
    "mcp_transport": [
      "routes/ai.php",
      "app/Mcp/Servers/AdminServer.php",
      "app/Mcp/Servers/MemberServer.php",
      "app/Mcp/Tools/Admin/*",
      "app/Mcp/Tools/Member/*",
      "app/Support/Mcp/McpWriteSchemaFormatter.php",
      "app/Support/Mcp/McpFilePayloadNormalizer.php"
    ],
    "verification": [
      "tests/Feature/Api/Admin/AdminApiTest.php",
      "tests/Feature/Mcp/AdminServerTest.php",
      "tests/Feature/Mcp/MemberServerTest.php",
      "tests/Feature/AdminResourcesCoverageTest.php",
      "tests/Unit/CrudComparisonDocsTest.php"
    ]
  },
  "surfaces": [
    {
      "key": "public_api",
      "auth_boundary": "public plus route-specific throttles",
      "contract_style": "workflow / discovery contracts",
      "purpose": "discovery, search, detail pages, auth entrypoints, public submit-event, guest-safe reads"
    },
    {
      "key": "authenticated_api",
      "auth_boundary": "auth:sanctum",
      "contract_style": "workflow / self-service contracts",
      "purpose": "contributions, GitHub issue reporting, reports, follows, saved searches, notifications, account settings, institution workspace, event state"
    },
    {
      "key": "admin_api",
      "auth_boundary": "auth:sanctum + EnsureAdminApiAccess",
      "contract_style": "generic resource HTTP contract",
      "purpose": "admin resource manifest, list/get/meta, related records, schema-guided create/update"
    },
    {
      "key": "admin_mcp",
      "auth_boundary": "auth:sanctum,api + EnsureAdminMcpAccess",
      "contract_style": "generic MCP tool contract",
      "purpose": "admin resource discovery, list/get/meta, related records, schema-guided create/update"
    },
    {
      "key": "member_mcp",
      "auth_boundary": "auth:sanctum,api + EnsureMemberMcpAccess",
      "contract_style": "scoped MCP tool contract",
      "purpose": "Ahli-scoped discovery, list/get/meta, schema-guided update, and member workflow tools for contribution queues and membership claims"
    },
    {
      "key": "admin_panel",
      "auth_boundary": "Filament admin panel",
      "contract_style": "UI/resource surface",
      "purpose": "full operational UI, relation managers, deletes/restores/reorders where the resource supports them"
    },
    {
      "key": "ahli_panel",
      "auth_boundary": "Filament Ahli panel",
      "contract_style": "UI/resource surface",
      "purpose": "member-scoped editing workspace for owned or linked records"
    }
  ],
  "workflow_api_families": {
    "public_discovery_and_form_contracts": [
      "GET /api/v1/manifest",
      "GET /api/v1/forms/submit-event",
