  "transport_rules": {
    "admin_api": {
      "schema_route_template": "GET /api/v1/admin/{resourceKey}/schema?operation=create|update&recordKey=...",
      "preview_mechanism": "validate_only=1 query parameter on POST/PUT; validation failures also include schema-driven feedback plus fix_plan, remaining_blockers, normalized_payload_preview, and can_retry",
      "apply_defaults_preview": true,
      "validation_feedback": true,
      "record_key_rule": "Use the admin record route_key returned by admin collection or detail payloads whenever available.",
      "validation_remediation_details": [
        "fix_plan",
        "remaining_blockers",
        "normalized_payload_preview",
        "can_retry"
      ],
      "batch_create_route": "POST /api/v1/admin/{resourceKey}/batch",
      "batch_update_route": "PUT /api/v1/admin/{resourceKey}/batch",
      "batch_max_items": 100,
      "batch_validate_only": true,
      "batch_external_row_id": true
    },
    "admin_mcp": {
      "schema_tool": "admin-get-write-schema",
      "create_tool": "admin-create-record",
      "update_tool": "admin-update-record",
      "content_type": "application/json",
      "validate_only": true,
      "apply_defaults": true,
      "validation_feedback": true,
      "media_upload_transport": "json_base64_descriptor",
      "destructive_clear_flags_supported": false,
      "validation_remediation_details": [
        "fix_plan",
        "remaining_blockers",
        "normalized_payload_preview",
        "can_retry"
      ],
      "batch_create_tool": "admin-batch-create-records",
      "batch_create_events_tool": "admin-batch-create-events",
      "batch_update_tool": "admin-batch-update-records",
      "batch_max_items": 100,
      "batch_events_max_items": 50,
      "batch_validate_only": true,
      "batch_external_row_id": true,
      "create_event_tool": "admin-create-event",
      "update_event_tool": "admin-update-event",
      "batch_update_events_tool": "admin-batch-update-events"
    },
    "member_mcp": {
      "schema_tool": "member-get-write-schema",
      "update_tool": "member-update-record",
      "content_type": "application/json",
      "validate_only": true,
      "related_records_tool": true,
      "media_upload_transport": "json_base64_descriptor",
      "destructive_clear_flags_supported": false
    }
  },
